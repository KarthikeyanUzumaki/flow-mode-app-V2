{
  "expo": {
    "name": "Flow Mode",
    "slug": "flow-mode-app",
    "version": "1.0.0",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Flow Mode needs camera access for real-time food detection.",
          "enableMicrophonePermission": false,
          "enableFrameProcessors": true
        }
      ],
      "react-native-fast-tflite",
      "expo-asset",
      "expo-font"
    ],
    "android": {
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.karthikuzumaki.flowmodeapp"
    }
  }
}
